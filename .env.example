# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/VOTRE_WEBHOOK_ID/VOTRE_WEBHOOK_TOKEN

# Optionnel: plusieurs webhooks séparés par virgule
# DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/.../...,https://discord.com/api/webhooks/.../...

# Filtre impact minimal (1=faible, 2=moyen, 3=fort)
# 3 = uniquement les annonces à fort impact (rouge)
# 2 = fort + moyen (rouge + orange)
# 1 = toutes les annonces
MIN_IMPACT=3

# Devises à surveiller (séparées par virgule, vide = toutes)
# Exemples: USD,EUR,GBP,JPY,CAD,AUD,CHF,NZD
CURRENCIES=USD,EUR,GBP,JPY

# Intervalle de vérification en minutes
CHECK_INTERVAL=5

# Boost de session : pré-chauffe + scans resserrés autour des ouvertures
# Londres (08:00 Europe/London) et New York (09:30 America/New_York).
# true = activé (recommandé), false = uniquement le scan périodique CHECK_INTERVAL
ENABLE_SESSION_BOOST=true
# Intervalle (minutes) des scans pendant les heures de session actives
SESSION_SCAN_INTERVAL=2

# Minutes avant l'annonce pour envoyer un rappel (0 = désactiver)
REMINDER_MINUTES=15

# Fuseau horaire (pour affichage)
TIMEZONE=Europe/Paris

# Sources actives (true/false)
ENABLE_FOREXFACTORY=true
ENABLE_INVESTING=true
